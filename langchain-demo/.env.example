# =============================================
# LangChain Demo 环境配置
# 将本文件复制为 .env 并填入你的 API Key
# =============================================

# 选择使用的 LLM 后端: openai 或 deepseek
LLM_PROVIDER=deepseek

# ---- OpenAI 配置 ----
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ---- DeepSeek 配置 (设置 LLM_PROVIDER=deepseek 时生效) ----
DEEPSEEK_API_KEY=sk-768e04f9f8ee44f69f98d2dba5bcf506
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
# 可选: deepseek-reasoner (DeepSeek-R1 推理模型)
