# .env.example — DeepSeek API 配置示例
# 复制此文件为 .env 并填入你的密钥
#   copy .env.example .env

# ═══════════════════════════════════════════════════════════════
# 方案 1：DeepSeek（推荐，性价比高）
# ═══════════════════════════════════════════════════════════════
# 注册地址：https://platform.deepseek.com
# API Key：在"API Keys"页面创建
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# 启用本地嵌入模型（免费，无需 OpenAI 密钥）
# 首次运行会自动下载 BAAI/bge-small-zh-v1.5（约 90MB）
USE_LOCAL_EMBEDDING=true

# ═══════════════════════════════════════════════════════════════
# 方案 2：OpenAI（可选）
# ═══════════════════════════════════════════════════════════════
# OPENAI_API_KEY=sk-your-openai-key-here

# ═══════════════════════════════════════════════════════════════
# 方案 3：无密钥（自动启用 Mock 模式，仅结构演示）
# ═══════════════════════════════════════════════════════════════
# 不设置任何密钥，项目自动以 Mock 模式运行
