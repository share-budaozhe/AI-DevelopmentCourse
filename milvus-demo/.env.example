# Milvus 连接配置

# ═══════════════════════════════════════════════════════════════
# 方案 1：Milvus Lite（推荐学习使用，无需 Docker）
# ═══════════════════════════════════════════════════════════════
# 不设置任何变量，项目自动使用 Milvus Lite（嵌入式）
# 数据存储在本地 ./milvus_data.db

# ═══════════════════════════════════════════════════════════════
# 方案 2：Milvus Standalone（Docker 部署）
# ═══════════════════════════════════════════════════════════════
# MILVUS_HOST=localhost
# MILVUS_PORT=19530

# ═══════════════════════════════════════════════════════════════
# 方案 3：Zilliz Cloud（托管服务）
# ═══════════════════════════════════════════════════════════════
# MILVUS_URI=https://xxx.api.zillizcloud.com
# MILVUS_TOKEN=your-token-here
