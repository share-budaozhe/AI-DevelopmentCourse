{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🔨 Build 构建知识库",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["build"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {"PYTHONIOENCODING": "utf-8"}
        },
        {
            "name": "🔍 Search 检索",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["search", "什么是机器学习"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {"PYTHONIOENCODING": "utf-8"}
        },
        {
            "name": "💬 Ask 完整问答",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["ask", "Python有哪些数据处理库"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {"PYTHONIOENCODING": "utf-8"}
        },
        {
            "name": "📊 Info 知识库状态",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["info"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {"PYTHONIOENCODING": "utf-8"}
        }
    ]
}
